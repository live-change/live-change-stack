{
  "name": "@live-change/codemirror-frontend",
  "version": "0.9.197",
  "type": "module",
  "scripts": {
    "memDev": "node server/start.js memDev --enableSessions --initScript ./init.js --dbAccess",
    "localDevInit": "rm tmp.db; lcli localDev --enableSessions --initScript ./init.js",
    "localDev": "node server/start.js localDev --enableSessions --dbAccess",
    "dev": "node server/start.js dev --enableSessions",
    "ssrDev": "node server/start.js ssrDev --enableSessions",
    "serveAllMem": "cross-env NODE_ENV=production lcli ssrServer --withApi --withServices --updateServices --enableSessions --withDb --dbBackend mem --createDb",
    "serveAll": "cross-env NODE_ENV=production lcli ssrServer --withApi --withServices --updateServices --enableSessions",
    "serve": "cross-env NODE_ENV=production lcli ssrServer --enableSessions",
    "apiServer": "node server/start.js apiServer --enableSessions",
    "devApiServer": "node server/start.js devApiServer --enableSessions",
    "memApiServer": "node server/start.js memApiServer --enableSessions",
    "build": "cd front; yarn build:client && yarn build:server",
    "build:client": "cd front; vite build --ssrManifest --outDir dist/client",
    "build:server": "cd front; vite build --ssr src/entry-server.js --outDir dist/server",
    "generate": "vite build --ssrManifest --outDir dist/static && yarn build:server && node prerender",
    "debug": "node --inspect-brk server"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.0.0",
    "@codemirror/collab": "^6.0.0",
    "@codemirror/lang-css": "^6.0.0",
    "@codemirror/lang-html": "^6.0.0",
    "@codemirror/lang-javascript": "^6.0.0",
    "@codemirror/lang-json": "^6.0.0",
    "@codemirror/lang-markdown": "^6.0.0",
    "@codemirror/lang-python": "^6.0.0",
    "@codemirror/language": "^6.0.0",
    "@codemirror/language-data": "^6.0.0",
    "@codemirror/lint": "^6.0.0",
    "@codemirror/state": "^6.0.0",
    "@codemirror/theme-one-dark": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "@lezer/markdown": "^1.0.0",
    "@live-change/access-control-service": "^0.9.197",
    "@live-change/cli": "^0.9.197",
    "@live-change/codemirror-service": "^0.9.197",
    "@live-change/dao": "^0.9.197",
    "@live-change/dao-vue3": "^0.9.197",
    "@live-change/dao-websocket": "^0.9.197",
    "@live-change/framework": "^0.9.197",
    "@live-change/session-service": "^0.9.197",
    "@live-change/url-service": "^0.9.197",
    "@live-change/user-service": "^0.9.197",
    "@live-change/vue3-components": "^0.9.197",
    "@live-change/vue3-ssr": "^0.9.197",
    "@replit/codemirror-indentation-markers": "^6.0.0",
    "@vueuse/core": "^12.3.0",
    "codemirror": "^6.0.0",
    "compression": "^1.7.5",
    "cross-env": "^7.0.3",
    "get-port-sync": "1.0.1",
    "serialize-javascript": "^6.0.2",
    "serve-static": "^1.16.2",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@live-change/codeceptjs-helper": "^0.9.197",
    "codeceptjs": "^3.6.10",
    "generate-password": "1.7.1",
    "playwright": "1.49.1",
    "random-profile-generator": "^2.3.0",
    "txtgen": "^3.0.7",
    "webdriverio": "^9.5.1"
  },
  "author": "Michał Łaszczewski <michal@laszczewski.pl>",
  "license": "ISC",
  "description": "",
  "gitHead": "7f358a1cc16fb35069f6ce3f897412232f766843"
}
